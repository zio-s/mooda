generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  user
  admin
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  name          String?
  image         String?
  password      String?
  role          UserRole  @default(user)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
  moodVotes     MoodVote[]
  reviews       Review[]
  favorites     UserFavorite[]
  collections   Collection[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Cafe {
  id            String    @id @default(cuid())
  name          String
  address       String
  addressDetail String?
  lat           Float
  lng           Float
  phone         String?
  kakaoPlaceId  String?   @unique
  googlePlaceId String?   @unique
  kakaoUrl      String?
  instagramUrl  String?
  website       String?
  description   String?   @db.Text
  district      String?
  neighborhood  String?
  avgRating     Float     @default(0)
  reviewCount   Int       @default(0)
  isVerified    Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  photos        CafePhoto[]
  hours         CafeHour[]
  moods         CafeMood[]
  moodVotes     MoodVote[]
  reviews       Review[]
  favorites     UserFavorite[]
  naverBlogCache NaverBlogCache[]
  googlePlaceCache GooglePlaceCache[]
  collectionItems CollectionItem[]

  @@index([lat, lng])
  @@index([district])
  @@map("cafes")
}

model Mood {
  id        String    @id @default(cuid())
  key       String    @unique
  label     String
  category  String
  emoji     String?
  sortOrder Int       @default(0)

  cafeMoods CafeMood[]
  moodVotes MoodVote[]

  @@map("moods")
}

model CafeMood {
  id        String   @id @default(cuid())
  cafeId    String
  moodId    String
  voteCount Int      @default(0)
  updatedAt DateTime @updatedAt

  cafe Cafe @relation(fields: [cafeId], references: [id], onDelete: Cascade)
  mood Mood @relation(fields: [moodId], references: [id], onDelete: Cascade)

  @@unique([cafeId, moodId])
  @@map("cafe_moods")
}

model MoodVote {
  id        String   @id @default(cuid())
  userId    String
  cafeId    String
  moodId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  cafe Cafe @relation(fields: [cafeId], references: [id], onDelete: Cascade)
  mood Mood @relation(fields: [moodId], references: [id], onDelete: Cascade)

  @@unique([userId, cafeId, moodId])
  @@map("mood_votes")
}

model CafePhoto {
  id        String   @id @default(cuid())
  cafeId    String
  url       String
  caption   String?
  isMain    Boolean  @default(false)
  createdAt DateTime @default(now())

  cafe Cafe @relation(fields: [cafeId], references: [id], onDelete: Cascade)

  @@map("cafe_photos")
}

model CafeHour {
  id         String  @id @default(cuid())
  cafeId     String
  dayOfWeek  Int
  openTime   String?
  closeTime  String?
  isClosed   Boolean @default(false)

  cafe Cafe @relation(fields: [cafeId], references: [id], onDelete: Cascade)

  @@unique([cafeId, dayOfWeek])
  @@map("cafe_hours")
}

model Review {
  id        String   @id @default(cuid())
  userId    String
  cafeId    String
  rating    Int
  content   String?  @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  cafe Cafe @relation(fields: [cafeId], references: [id], onDelete: Cascade)

  @@unique([userId, cafeId])
  @@map("reviews")
}

model UserFavorite {
  id        String   @id @default(cuid())
  userId    String
  cafeId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  cafe Cafe @relation(fields: [cafeId], references: [id], onDelete: Cascade)

  @@unique([userId, cafeId])
  @@map("user_favorites")
}

model Collection {
  id          String   @id @default(cuid())
  userId      String
  name        String
  description String?
  isPublic    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user  User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  items CollectionItem[]

  @@map("collections")
}

model CollectionItem {
  id           String   @id @default(cuid())
  collectionId String
  cafeId       String
  createdAt    DateTime @default(now())

  collection Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  cafe       Cafe       @relation(fields: [cafeId], references: [id], onDelete: Cascade)

  @@unique([collectionId, cafeId])
  @@map("collection_items")
}

model NaverBlogCache {
  id        String   @id @default(cuid())
  cafeId    String
  data      Json
  expiresAt DateTime
  createdAt DateTime @default(now())

  cafe Cafe @relation(fields: [cafeId], references: [id], onDelete: Cascade)

  @@map("naver_blog_cache")
}

model GooglePlaceCache {
  id        String   @id @default(cuid())
  cafeId    String
  data      Json
  expiresAt DateTime
  createdAt DateTime @default(now())

  cafe Cafe @relation(fields: [cafeId], references: [id], onDelete: Cascade)

  @@map("google_place_cache")
}

model SearchLog {
  id          String   @id @default(cuid())
  query       Json
  resultCount Int
  createdAt   DateTime @default(now())

  @@map("search_logs")
}
