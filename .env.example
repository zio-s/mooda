# Database
DATABASE_URL="postgresql://user:password@localhost:5432/mooda"

# Redis
REDIS_HOST="localhost"
REDIS_PORT="6379"
REDIS_PASSWORD=""

# NextAuth
AUTH_SECRET="your-secret-key-here-min-32-chars"
NEXTAUTH_URL="http://localhost:3000"

# Kakao OAuth (https://developers.kakao.com)
KAKAO_CLIENT_ID="your-kakao-rest-api-key"
KAKAO_CLIENT_SECRET="your-kakao-client-secret"

# Kakao Maps JS SDK
NEXT_PUBLIC_KAKAO_MAP_APP_KEY="your-kakao-js-app-key"

# Kakao Local API (server-side)
KAKAO_REST_API_KEY="your-kakao-rest-api-key"

# Naver Search API (https://developers.naver.com)
NAVER_CLIENT_ID="your-naver-client-id"
NAVER_CLIENT_SECRET="your-naver-client-secret"

# Google Places API
GOOGLE_PLACES_API_KEY="your-google-places-api-key"

# AWS (production only)
AWS_REGION="ap-northeast-2"
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_S3_BUCKET=""
CLOUDFRONT_URL=""
